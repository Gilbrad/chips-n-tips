NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-web-push-vapid-public-key

# Keep false until Confirm email is disabled in the Supabase dashboard.
NEXT_PUBLIC_ENABLE_EMAIL_SIGNUP=false

# Development only: set true temporarily when testing real PWA push on localhost.
# Keep false during normal dev so stale service workers are cleared.
NEXT_PUBLIC_ENABLE_DEV_PUSH=false

# Supabase Edge Function secrets, configured with:
# supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... VAPID_SUBJECT=mailto:you@example.com CRON_SECRET=...
# VAPID_PUBLIC_KEY should match NEXT_PUBLIC_VAPID_PUBLIC_KEY.
